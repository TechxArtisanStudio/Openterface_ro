---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="Video"
  description="Demonstrații de produse Openterface, tutoriale și recenzii pe YouTube."
  canonicalPath="/videos/"
>
  <DocLinkBanner message="Grila video completă și filtrabilă de pe YouTube se află pe site-ul vechi până când vom porta fluxul video." />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl font-bold">Video</h1>
      <p class="mt-4 text-lg text-muted">
        Urmăriți demonstrații de produse, ghiduri de configurare și recenzii ale comunității pentru produsele Openterface KVM și KeyMod.
      </p>
      <a href={legacyPath('/videos/')} class="btn btn-primary mt-8" target="_blank" rel="noopener">
        Răsfoiește toate videoclipurile →
      </a>
    </div>
  </section>
</BaseLayout>
