---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="Cazuri de utilizare"
  description="Cazuri de utilizare din lumea reală pentru produsele KVM-over-USB Openterface."
  canonicalPath="/use-cases/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">Cazuri de utilizare</h1>
      <p class="mt-4 text-lg text-muted">
        Instrumentele Openterface excelează ori de câte ori aveți nevoie să controlați un calculator fără monitor sau greu accesibil fără un
        monitor și o tastatură dedicate.
      </p>
      <ul class="mt-8 space-y-4">
        {
          [
            'Inspecții în centre de date și colocare',
            'Administrare homelab și NAS',
            'Lansare dispozitive embedded și SBC',
            'Întreținere chioșcuri și semnalizare digitală',
            'Angajamente IT pe teren și consultanță',
          ].map((item) => (
            <li class="card">{item}</li>
          ))
        }
      </ul>
      <a href={legacyPath('/use-cases/')} class="btn btn-secondary mt-8" target="_blank" rel="noopener">
        Vezi galeria completă de cazuri de utilizare →
      </a>
    </div>
  </section>
</BaseLayout>
