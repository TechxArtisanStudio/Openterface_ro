---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pagina nu a fost găsită" description="Pagina pe care ați solicitat-o nu a putut fi găsită." canonicalPath="/404">
  <section class="flex min-h-[50vh] flex-col items-center justify-center px-4 py-16 text-center">
    <h1 class="text-6xl font-bold text-primary-dark">404</h1>
    <p class="mt-4 text-xl text-muted">Pagina nu a fost găsită</p>
    <a href="/" class="btn btn-primary mt-8">Înapoi la Acasă</a>
  </section>
</BaseLayout>
