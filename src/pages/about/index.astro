---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLinkBanner from '../../components/DocLinkBanner.astro';
import { legacyPath } from '../../config/site';
---

<BaseLayout
  title="Despre Openterface"
  description="Află mai multe despre Openterface — soluții KVM-over-USB open-source construite de TechxArtisan."
  canonicalPath="/about/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">Despre Openterface</h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        Openterface construiește instrumente KVM-over-USB ultra-compacte și open-source pentru profesioniști IT, dezvoltatori și makeri.
        De la Mini-KVM-ul finanțat prin crowdfunding până la KVM-GO de mărimea unui breloc și seria programabilă KeyMod, misiunea noastră este
        to simplificăm controlul calculatoarelor fără monitor fără echipamente voluminoase sau rețele complexe.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={legacyPath('/about/about-us/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Despre noi complet →
        </a>
        <a href={legacyPath('/about/compliance/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Conformitate →
        </a>
        <a href={legacyPath('/about/community/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Comunitate →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
